{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto"
      },
      "title": "Pipeline Success Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "(sum(airflow_dag_processing_total_parse_time{dag_id=\"transaction_pipeline\"}) / count(airflow_dag_processing_total_parse_time{dag_id=\"transaction_pipeline\"})) * 100",
          "legendFormat": "Success Rate"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 120 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "title": "Avg Task Duration",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(airflow_ti_finish - airflow_ti_start)",
          "legendFormat": "Duration"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "title": "Data Quality Score",
      "type": "gauge",
      "targets": [
        {
          "expr": "(pipeline_quality_passed / (pipeline_quality_passed + pipeline_quality_failed)) * 100",
          "legendFormat": "Quality Score"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "red", "value": 120 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "title": "SLA Compliance",
      "type": "stat",
      "targets": [
        {
          "expr": "pipeline_e2e_latency_seconds",
          "legendFormat": "E2E Latency"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "title": "Records Processed Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "pipeline_rows_ingested",
          "legendFormat": "Ingested"
        },
        {
          "expr": "pipeline_rows_staged",
          "legendFormat": "Staged"
        },
        {
          "expr": "pipeline_fact_rows",
          "legendFormat": "Loaded to Facts"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "title": "Task Execution Timeline",
      "type": "timeseries",
      "targets": [
        {
          "expr": "airflow_ti_successes{dag_id=\"transaction_pipeline\"}",
          "legendFormat": "{{ task_id }} successes"
        },
        {
          "expr": "airflow_ti_failures{dag_id=\"transaction_pipeline\"}",
          "legendFormat": "{{ task_id }} failures"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["pipeline", "transactions", "etl"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Transaction Pipeline Health",
  "uid": "txn-pipeline-health",
  "version": 1
}
