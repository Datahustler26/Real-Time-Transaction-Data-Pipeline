.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# --- Data ---
*.csv
!tests/fixtures/sample_transactions.csv
*.parquet
*.json.gz
data/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Secrets ---
.env
*.pem
*.key
credentials.json

